{
  "name": "mynab",
  "version": "0.1.0",
  "private": true,
  "main": "electron/main.js",
  "scripts": {
    "dev": "next dev",
    "dev:sqlite": "DB_PROVIDER=sqlite DATABASE_URL=file:./prisma/dev.db next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "test": "npm run check:schema-parity && vitest run",
    "check:schema-parity": "tsx scripts/check-schema-parity.ts",
    "db:generate": "prisma generate --schema prisma/schema.postgres.prisma && prisma generate --schema prisma/schema.sqlite.prisma",
    "electron:prepare": "npm rebuild better-sqlite3 && ELECTRON_BUILD=1 next build && node scripts/prepare-standalone.mjs && node scripts/desymlink-standalone.mjs",
    "electron:rebuild-native": "electron-rebuild -f -w better-sqlite3 && node scripts/sync-standalone-native.mjs",
    "electron:dev": "npm run electron:prepare && npm run electron:rebuild-native && electron .",
    "electron:pack": "npm run electron:prepare && npm run electron:rebuild-native && electron-builder",
    "electron:pack:mac:universal": "npm run electron:prepare && node scripts/build-fat-sqlite.mjs && node scripts/sync-standalone-native.mjs && electron-builder --mac --universal",
    "electron:pack:win": "npm run electron:prepare && electron-builder --win --x64"
  },
  "dependencies": {
    "@prisma/adapter-better-sqlite3": "^7.8.0",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "better-sqlite3": "^12.11.1",
    "lucide-react": "^1.24.0",
    "next": "16.2.10",
    "pg": "^8.22.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "recharts": "^3.9.2"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.2.0",
    "@types/node": "^20",
    "@types/pg": "^8.20.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "dotenv": "^17.4.2",
    "electron": "^42.7.0",
    "electron-builder": "^26.15.3",
    "eslint": "^9",
    "eslint-config-next": "16.2.10",
    "prisma": "^7.8.0",
    "tsx": "^4.23.1",
    "typescript": "^5",
    "vitest": "^4.1.10"
  },
  "build": {
    "appId": "com.mynab.desktop",
    "productName": "mynab",
    "directories": {
      "output": "dist-electron"
    },
    "npmRebuild": false,
    "files": [
      "electron/**/*",
      "package.json",
      "!node_modules/**/*",
      "node_modules/better-sqlite3/**/*",
      "node_modules/bindings/**/*",
      "node_modules/file-uri-to-path/**/*",
      "!node_modules/better-sqlite3/bin/**/*",
      "!node_modules/better-sqlite3/build/Release/test_extension.node"
    ],
    "asarUnpack": [
      "node_modules/better-sqlite3/**/*"
    ],
    "extraResources": [
      {
        "from": "prisma/schema.sqlite.prisma",
        "to": "app/prisma/schema.sqlite.prisma"
      },
      {
        "from": "prisma/migrations-sqlite",
        "to": "app/prisma/migrations-sqlite",
        "filter": [
          "**/*"
        ]
      }
    ],
    "afterPack": "scripts/electron-after-pack.mjs",
    "win": {
      "target": "nsis"
    },
    "mac": {
      "target": "dmg",
      "identity": null
    },
    "linux": {
      "target": "AppImage"
    }
  },
  "allowScripts": {
    "@prisma/engines@7.8.0": true,
    "better-sqlite3@12.11.1": true,
    "electron-winstaller@5.4.0": true,
    "esbuild@0.28.1": true,
    "fsevents@2.3.3": true,
    "prisma@7.8.0": true,
    "sharp@0.34.5": true,
    "unrs-resolver@1.12.2": true,
    "electron@42.7.0": true
  }
}
