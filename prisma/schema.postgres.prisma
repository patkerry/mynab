// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma-postgres"
}

datasource db {
  provider = "postgresql"
}

enum AccountType {
  CHECKING
  SAVINGS
  CREDIT
}

enum TransactionKind {
  NORMAL
  INCOME
  TRANSFER
}

enum GoalType {
  MONTHLY
  TARGET
}

// Role of a user within a budget. OWNER can manage members + delete the budget; EDITOR can change
// budget data; VIEWER is read-only. Enforced in the data-access layer (see src/lib/budget-context.ts).
enum MembershipRole {
  OWNER
  EDITOR
  VIEWER
}

// The ownership boundary for the whole app: every Account/Category/Transaction/etc. belongs to
// exactly one Budget. A single-user setup is just a Budget with one OWNER membership; a shared
// household is a Budget with several memberships. The embedded desktop (SQLite) build uses exactly
// one Budget and no users/memberships — see electron/main.js and src/lib/budget-context.ts.
model Budget {
  id              String           @id @default(cuid())
  name            String
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  accounts        Account[]
  categoryGroups  CategoryGroup[]
  categories      Category[]
  budgetEntries   BudgetEntry[]
  transactions    Transaction[]
  reconciliations Reconciliation[]
  memberships     Membership[]
  invites         Invite[]

  @@map("budgets")
}

// Web-only auth identity (Google OAuth via Auth.js). Never populated by the desktop build.
model User {
  id          String       @id @default(cuid())
  email       String       @unique
  name        String?
  image       String?
  // Global app administrator (can access /admin to manage all users/budgets). Bootstrapped via the
  // set-admin script (scripts/set-admin.ts); there's no in-app "make admin" flow by design.
  isAdmin     Boolean      @default(false)
  // Set when an admin suspends the account: blocks new logins and all data access until cleared.
  suspendedAt DateTime?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  memberships Membership[]
  invitesSent Invite[]     @relation("InviteInviter")

  @@map("users")
}

// Join between a User and a Budget, carrying the user's role in that budget.
model Membership {
  id        String         @id @default(cuid())
  userId    String
  user      User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  budgetId  String
  budget    Budget         @relation(fields: [budgetId], references: [id], onDelete: Cascade)
  role      MembershipRole @default(EDITOR)
  createdAt DateTime       @default(now())

  @@unique([userId, budgetId])
  @@index([budgetId])
  @@map("memberships")
}

// A pending invitation for someone to join a budget (Phase 2: sharing). Accepting it creates a
// Membership. token is the unguessable value embedded in the invite link.
model Invite {
  id          String         @id @default(cuid())
  budgetId    String
  budget      Budget         @relation(fields: [budgetId], references: [id], onDelete: Cascade)
  email       String
  role        MembershipRole @default(EDITOR)
  token       String         @unique
  invitedById String
  invitedBy   User           @relation("InviteInviter", fields: [invitedById], references: [id], onDelete: Cascade)
  createdAt   DateTime       @default(now())
  acceptedAt  DateTime?

  @@unique([budgetId, email])
  @@index([budgetId])
  @@map("invites")
}

model Account {
  id              String           @id @default(cuid())
  budgetId        String
  budget          Budget           @relation(fields: [budgetId], references: [id], onDelete: Cascade)
  name            String
  type            AccountType
  onBudget        Boolean          @default(true)
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  transactions    Transaction[]
  paymentCategory Category? // the linked "pay this card" category, if this is a credit account
  reconciliations Reconciliation[]

  @@index([budgetId])
  @@map("accounts")
}

model CategoryGroup {
  id         String     @id @default(cuid())
  budgetId   String
  budget     Budget     @relation(fields: [budgetId], references: [id], onDelete: Cascade)
  name       String
  isHidden   Boolean    @default(false) // e.g. the singleton "Credit Card Payments" group
  sortOrder  Int        @default(0) // manual drag-and-drop ordering; 0 falls back to createdAt order
  createdAt  DateTime   @default(now())
  categories Category[]

  @@index([budgetId])
  @@map("category_groups")
}

model Category {
  id              String        @id @default(cuid())
  budgetId        String
  budget          Budget        @relation(fields: [budgetId], references: [id], onDelete: Cascade)
  groupId         String
  group           CategoryGroup @relation(fields: [groupId], references: [id], onDelete: Restrict)
  name            String
  goalType        GoalType?
  goalAmountCents Int?
  // User-facing hide (e.g. a one-off category like "Concert" they don't need to see going
  // forward). Purely a display filter in BudgetView — engine math (available/RTA/goals),
  // transaction history, and the category picker are all completely unaffected; a hidden
  // category still works exactly like any other, it just doesn't clutter the main budget list.
  isHidden        Boolean       @default(false)
  sortOrder       Int           @default(0) // manual drag-and-drop ordering; 0 falls back to createdAt order
  // Set only on a card's auto-created payment category. Its monthly activity is DERIVED
  // (see computeDerived in src/lib/budget.ts) rather than summed from transactions tagged
  // with this category's own id, the way every other category works.
  linkedAccountId String?       @unique
  linkedAccount   Account?      @relation(fields: [linkedAccountId], references: [id], onDelete: Cascade)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  budgetEntries   BudgetEntry[]
  transactions    Transaction[]

  @@index([budgetId])
  @@index([groupId])
  @@map("categories")
}

model BudgetEntry {
  id          String   @id @default(cuid())
  budgetId    String
  budget      Budget   @relation(fields: [budgetId], references: [id], onDelete: Cascade)
  categoryId  String
  category    Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  yearMonth   String // "YYYY-MM"
  amountCents Int
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([categoryId, yearMonth])
  @@index([budgetId])
  @@index([yearMonth])
  @@map("budget_entries")
}

model Transaction {
  id                   String          @id @default(cuid())
  budgetId             String
  budget               Budget          @relation(fields: [budgetId], references: [id], onDelete: Cascade)
  accountId            String
  account              Account         @relation(fields: [accountId], references: [id], onDelete: Restrict)
  date                 String // "YYYY-MM-DD" — zero-padded for correct lexicographic ordering
  payee                String
  memo                 String          @default("")
  kind                 TransactionKind @default(NORMAL)
  categoryId           String?
  category             Category?       @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  amountCents          Int // signed cents; positive = inflow, negative = outflow
  cleared              Boolean         @default(false)
  // True until a file-imported row is reviewed/approved. Excluded from category
  // activity/available and totalIncome (see buildActivityByMonth/computeDerived in
  // src/lib/budget.ts) but still counted in acctBalance/netWorth — the money already moved in
  // real life, it just hasn't been assigned a job yet. Saving any edit (see updateTransaction
  // in accounts/actions.ts) clears it — that save IS the approval, no separate action needed.
  pending              Boolean         @default(false)
  // Bank-assigned FITID from a QFX/OFX import; null for CSV/manual entries. Unique per account
  // so re-importing an overlapping QFX file is a no-op for rows already present (see
  // importTransactions in accounts/actions.ts, which inserts with skipDuplicates: true).
  externalId           String?
  transferId           String? // shared by both legs of a transfer
  // Set only on TRANSFER legs, to the OTHER leg's accountId. Lets the UI render a live
  // "Transfer to/from <account name>" label (see transferLabel in src/lib/budget.ts) by looking
  // this id up in an already-loaded Account[] list, the same way resolveBreakdown in
  // BudgetView.tsx already does for card payments — instead of baking in a name string at
  // creation time that would go stale the moment account renaming exists. Plain scalar, no
  // @relation: never queried by, only ever resolved against a list already in memory.
  counterpartAccountId String?
  // Set instead of a real delete (see deleteTransaction in accounts/actions.ts) — keeps the
  // row's externalId occupied so a later overlapping QFX import can't silently resurrect
  // something the user deliberately removed. Every read path filters deletedAt: null.
  deletedAt            DateTime?
  createdAt            DateTime        @default(now())
  updatedAt            DateTime        @updatedAt
  reconciliation       Reconciliation? // set if this transaction is the adjustment a reconciliation produced

  @@unique([accountId, externalId])
  @@index([budgetId])
  @@index([accountId, date])
  @@index([categoryId, date])
  @@index([kind])
  @@index([transferId])
  @@map("transactions")
}

// One row per reconciliation performed, whether or not it produced an adjustment — this is the
// audit trail the "Reconcile" flow (src/app/accounts/actions.ts) didn't have before: without
// it, a clean reconciliation (statement balance already matched) left zero trace anywhere.
model Reconciliation {
  id                      String       @id @default(cuid())
  budgetId                String
  budget                  Budget       @relation(fields: [budgetId], references: [id], onDelete: Cascade)
  accountId               String
  account                 Account      @relation(fields: [accountId], references: [id], onDelete: Cascade)
  date                    String // "YYYY-MM-DD", the day the reconciliation was performed
  statementBalanceCents   Int // the actual balance the user entered
  adjustmentCents         Int // 0 if the tracked balance already matched
  adjustmentTransactionId String?      @unique
  // SetNull (not Restrict/Cascade): if the user later deletes the adjustment transaction from
  // the register, the reconciliation record — the audit trail itself — should still stand;
  // it just loses the link to a transaction that no longer exists.
  adjustmentTransaction   Transaction? @relation(fields: [adjustmentTransactionId], references: [id], onDelete: SetNull)
  createdAt               DateTime     @default(now())

  @@index([budgetId])
  @@index([accountId, date])
  @@map("reconciliations")
}
